# ============================================================
# Environment Variables — Local Backend
# ============================================================

# Opsi 1: SQLite (Nol Konfigurasi — Default & Sangat Ringan)
# Database akan disimpan sebagai file lokal 'backend/kangbejo.db'
DATABASE_URL=sqlite:///./kangbejo.db

# Opsi 2: PostgreSQL Lokal (Sesuai Modul 2 - 4)
# Un-comment dan sesuaikan password jika diwajibkan menggunakan PostgreSQL
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/kangbejo

# JWT Secret Key (generate string acak: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-minimum-32-characters-replace-this

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
