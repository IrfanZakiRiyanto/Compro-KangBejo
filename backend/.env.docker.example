# ============================================================
# Environment Variables — Backend Docker (TEMPLATE)
# Modul 7: Docker Compose
# ============================================================
# Salin file ini menjadi .env.docker lalu isi nilainya:
#   cp .env.docker.example .env.docker
# ============================================================

# Database (host = nama service "db" di docker-compose.yml)
DATABASE_URL=postgresql://postgres:PASSWORD_KAMU@db:5432/kangbejo

# JWT Secret Key (generate string acak: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-minimum-32-characters-replace-this

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173
